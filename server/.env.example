# Copy this to .env and fill the values
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
# Optional comma-separated list for additional allowed origins
ALLOWED_ORIGINS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1XXXXXXXXXX
BOOKINGS_SMS_TO=+233555182969
# Set to true to also send a short confirmation SMS to the customer phone (must be E.164)
SEND_CONFIRMATION_TO_CUSTOMER=false

# PostgreSQL (optional - reviews will use JSON/Firestore fallback if not set)
# DATABASE_URL=postgresql://user:password@localhost:5432/sista_events
# Or use individual PG* vars below:
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=sista_events
# PGUSER=postgres
# PGPASSWORD=
